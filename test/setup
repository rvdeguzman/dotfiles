#!/usr/bin/env bash
set -eu

ROOT=$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd -P)
TEST_HOME=$(mktemp -d)
trap 'rm -rf "$TEST_HOME"' EXIT

/bin/bash -n "$ROOT/setup"
command -v shellcheck >/dev/null 2>&1 && shellcheck "$ROOT/setup"

preview=$(HOME="$TEST_HOME" "$ROOT/setup" --dry-run link shell)
case "$preview" in
  *'+ ln -s '*) ;;
  *) printf 'dry run did not print planned links\n' >&2; exit 1 ;;
esac

if find "$TEST_HOME" -mindepth 1 -print -quit | grep -q .; then
  printf 'dry run changed the isolated home directory\n' >&2
  exit 1
fi

assert_line() {
  printf '%s\n' "$1" | grep -Fqx -- "$2" || {
    printf 'missing expected line: %s\n' "$2" >&2
    exit 1
  }
}

refute_line() {
  if printf '%s\n' "$1" | grep -Fqx -- "$2"; then
    printf 'unexpected line: %s\n' "$2" >&2
    exit 1
  fi
}

FAKE_BIN="$TEST_HOME/fake-bin"
mkdir -p "$FAKE_BIN"
ln -s "$(command -v bash)" "$FAKE_BIN/bash"
ln -s "$(command -v dirname)" "$FAKE_BIN/dirname"
cat >"$FAKE_BIN/uname" <<'SCRIPT'
#!/bin/sh
printf '%s\n' "${FAKE_UNAME:-Linux}"
SCRIPT
chmod +x "$FAKE_BIN/uname"

macos_list=$(FAKE_UNAME=Darwin PATH="$FAKE_BIN" "$ROOT/setup" list)
assert_line "$macos_list" "Components (macOS):"
assert_line "$macos_list" "  aerospace"
refute_line "$macos_list" "  hypr"
refute_line "$macos_list" "  waybar"
assert_line "$macos_list" "  apps"
assert_line "$macos_list" "  core"
assert_line "$macos_list" "  dev"

linux_list=$(FAKE_UNAME=Linux PATH="$FAKE_BIN" "$ROOT/setup" list)
assert_line "$linux_list" "Components (Linux):"
assert_line "$linux_list" "  hypr"
assert_line "$linux_list" "  waybar"
refute_line "$linux_list" "  aerospace"
refute_line "$linux_list" "  karabiner"
assert_line "$linux_list" "Package profiles (Linux):"

cat >"$FAKE_BIN/pacman" <<'SCRIPT'
#!/bin/sh
exit 1
SCRIPT
chmod +x "$FAKE_BIN/pacman"

arch_list=$(FAKE_UNAME=Linux PATH="$FAKE_BIN" "$ROOT/setup" list)
assert_line "$arch_list" "Components (Arch Linux):"
assert_line "$arch_list" "  hypr"
refute_line "$arch_list" "  aerospace"
assert_line "$arch_list" "  base"
assert_line "$arch_list" "  hyprland"
assert_line "$arch_list" "  i3"

if command -v expect >/dev/null 2>&1; then
  SETUP_ROOT="$ROOT" TEST_HOME="$TEST_HOME" expect <<'EXPECT'
set timeout 10
log_user 0

spawn env HOME=$env(TEST_HOME) $env(SETUP_ROOT)/setup --dry-run
expect -exact "Configuration components"
send "\r"
expect {
  -exact "Package profiles" {
    send "\r"
    exp_continue
  }
  -exact "--dry-run is active" {}
}
expect -exact "Preview"
expect eof

spawn env HOME=$env(TEST_HOME) $env(SETUP_ROOT)/setup
expect -exact "Configuration components"
send "j"
expect -exact "Configuration components"
send "k"
expect -exact "Configuration components"
send " "
expect -exact "Configuration components"
send "\r"
expect {
  -exact "Package profiles" {
    send "j"
    expect -exact "Package profiles"
    send "k"
    expect -exact "Package profiles"
    send " "
    expect -exact "Package profiles"
    send "\r"
    exp_continue
  }
  -exact "Review" {}
}
expect -exact "(default: preview): "
send "q\r"
expect -exact "No changes made."
expect eof

spawn env HOME=$env(TEST_HOME) $env(SETUP_ROOT)/setup
expect -exact "Configuration components"
send "q"
expect -exact "No changes made."
expect eof
EXPECT
else
  printf 'expect not installed; skipped pseudo-terminal selector check\n'
fi

printf 'setup checks passed\n'
