// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "outline_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "ui_font_family": "Iosevka Nerd Font Mono",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
    "show": true,
  },
  "search": {
    "button": false,
  },
  "diagnostics": {
    "button": true,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "button": false,
  },
  "status_bar": {
    "cursor_position_button": true,
    "active_language_button": true,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "show_wrap_guides": true,
  "wrap_guides": [80],
  "scrollbar": {
    "show": "never",
  },
  "hover_popover_delay": 500,
  "icon_theme": {
    "mode": "dark",
    "light": "VSCode Icons for Zed (Dark)",
    "dark": "VSCode Icons for Zed (Dark)"
  },
  "project_panel": {
    "button": false,
    "dock": "right",
  },
  "use_system_window_tabs": true,
  "title_bar": {
    "show_user_picture": false,
    "show_menus": true,
    "show_branch_icon": true,
  },
  "inlay_hints": {
    "enabled": false,
  },
  "vim": {
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
  },
  "toolbar": {
    "breadcrumbs": true,
    "code_actions": false,
  },
  "relative_line_numbers": "enabled",
  "show_signature_help_after_edits": false,
  "sticky_scroll": {
    "enabled": false,
  },
  "auto_signature_help": false,
  "which_key": {
    "enabled": false,
  },
  "rounded_selection": true,
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_features": {
    "calt": false,
  },
  "agent": {
    "dock": "right",
    "single_file_review": false,
    "show_turn_stats": true,
    "enable_feedback": false,
    "tool_permissions": {
      "default": "allow",
      "tools": {},
    },
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "provider": "zed.dev",
      "model": "gpt-5.4",
      "enable_thinking": true,
    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "gpt-5.4",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": false
      }
    ],
    "model_parameters": [],
  },
  "agent_servers": {
    "opencode": {
      "type": "registry",
      "favorite_models": ["opencode/kimi-k2.5"],
    },
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
    "amp-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "favorite_config_option_values": {
        "mode": [
          "full-access"
        ]
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Ars Goetia - Kimaris",
  },
}
