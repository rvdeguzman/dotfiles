#!/usr/bin/env bash
# Compatible with macOS's Bash 3.2.
set -e

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

script_path=$0
case "$script_path" in
  */*) ;;
  *)
    if [ -f "$script_path" ]; then
      script_path="./$script_path"
    else
      script_path=$(command -v "$script_path") || fail "Cannot locate setup script"
    fi
    ;;
esac
REPO_DIR=$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd -P)
CONFIGS_DIR="$REPO_DIR/configs"
PACKAGES_DIR="$REPO_DIR/packages"
BACKUP_ROOT=""
DRY_RUN=0

case "$(uname -s)" in
  Darwin)
    OS_KIND="macos"
    PROFILE_KIND="macos"
    PROFILE_DIR="$PACKAGES_DIR/macos"
    PROFILE_EXTENSION=".Brewfile"
    ;;
  Linux)
    OS_KIND="linux"
    if [ -e /etc/arch-release ] || command -v pacman >/dev/null 2>&1; then
      PROFILE_KIND="arch"
      PROFILE_DIR="$PACKAGES_DIR/arch"
      PROFILE_EXTENSION=".txt"
    else
      PROFILE_KIND="unsupported"
      PROFILE_DIR=""
      PROFILE_EXTENSION=""
    fi
    ;;
  *)
    OS_KIND="other"
    PROFILE_KIND="unsupported"
    PROFILE_DIR=""
    PROFILE_EXTENSION=""
    ;;
esac

discover_all_components() {
  ALL_COMPONENTS=()
  local directory
  for directory in "$CONFIGS_DIR"/*; do
    [ -d "$directory" ] || continue
    ALL_COMPONENTS[${#ALL_COMPONENTS[@]}]=${directory##*/}
  done
}

component_supported_on_platform() {
  case "$1" in
    aerospace|cmux|karabiner|omniwm)
      [ "$OS_KIND" = "macos" ]
      ;;
    hypr|hypr-minibook|mako|waybar|wofi)
      [ "$OS_KIND" = "linux" ]
      ;;
    *)
      return 0
      ;;
  esac
}

discover_components() {
  discover_all_components
  COMPONENTS=()
  local component
  for component in "${ALL_COMPONENTS[@]}"; do
    component_supported_on_platform "$component" || continue
    COMPONENTS[${#COMPONENTS[@]}]="$component"
  done
}

discover_profiles() {
  PROFILES=()
  [ "$PROFILE_KIND" = "unsupported" ] && return

  local file name
  for file in "$PROFILE_DIR"/*"$PROFILE_EXTENSION"; do
    [ -f "$file" ] || continue
    name=${file##*/}
    name=${name%"$PROFILE_EXTENSION"}
    PROFILES[${#PROFILES[@]}]="$name"
  done
}

contains() {
  local wanted=$1 candidate
  shift
  for candidate in "$@"; do
    [ "$candidate" = "$wanted" ] && return 0
  done
  return 1
}

print_list() {
  local heading=$1 item
  shift
  printf '%s:\n' "$heading"
  if [ "$#" -eq 0 ]; then
    printf '  (none)\n'
    return
  fi
  for item in "$@"; do
    printf '  %s\n' "$item"
  done
}

list() {
  discover_components
  print_list "Components ($(platform_label))" "${COMPONENTS[@]}"
  discover_profiles
  print_list "Package profiles ($(platform_label))" "${PROFILES[@]}"
}

backup_root() {
  if [ -z "$BACKUP_ROOT" ]; then
    BACKUP_ROOT="$HOME/.local/state/dotfiles/backups/$(date +%Y%m%d-%H%M%S)-$$"
  fi
}

link_file() {
  local source=$1 relative=$2 target target_parent backup
  target="$HOME/$relative"

  if [ -L "$target" ] && [ "$target" -ef "$source" ]; then
    printf 'Skipping linked file: %s\n' "$target"
    return
  fi

  if [ -e "$target" ] || [ -L "$target" ]; then
    backup_root
    backup="$BACKUP_ROOT/$relative"
    if [ "$DRY_RUN" -eq 1 ]; then
      printf '+ mkdir -p %s\n' "$(dirname "$backup")"
      printf '+ mv %s %s\n' "$target" "$backup"
    else
      [ ! -e "$backup" ] && [ ! -L "$backup" ] || fail "Backup already exists: $backup"
      mkdir -p "$(dirname "$backup")"
      mv "$target" "$backup"
    fi
  fi

  target_parent=$(dirname "$target")
  if [ "$DRY_RUN" -eq 1 ]; then
    printf '+ mkdir -p %s\n' "$target_parent"
    printf '+ ln -s %s %s\n' "$source" "$target"
  else
    mkdir -p "$target_parent"
    ln -s "$source" "$target"
  fi
}

link_component() {
  local component=$1 component_dir source relative
  component_dir="$CONFIGS_DIR/$component"
  if [ ! -d "$component_dir" ]; then
    printf 'Skipping vanished component: %s\n' "$component" >&2
    return
  fi

  while IFS= read -r -d '' source; do
    [ -f "$source" ] || {
      printf 'Skipping vanished config file: %s\n' "$source" >&2
      continue
    }
    relative=${source#"$component_dir"/}
    link_file "$source" "$relative"
  done < <(find "$component_dir" -type f -print0)
}

link_components() {
  discover_all_components
  local component
  if [ "$#" -eq 0 ]; then
    discover_components
    set -- "${COMPONENTS[@]}"
  fi
  if [ "$#" -eq 0 ]; then
    printf 'No components found in %s\n' "$CONFIGS_DIR"
    return
  fi

  for component in "$@"; do
    contains "$component" "${ALL_COMPONENTS[@]}" || fail "Unknown component: $component"
    link_component "$component"
  done
}

select_profiles() {
  discover_profiles
  [ "$PROFILE_KIND" != "unsupported" ] || fail "Packages are supported on macOS and Arch Linux"

  SELECTED_PROFILES=()
  local profile
  if [ "$#" -eq 0 ]; then
    set -- "${PROFILES[@]}"
  fi
  if [ "$#" -eq 0 ]; then
    printf 'No package profiles found in %s\n' "$PROFILE_DIR"
    return
  fi

  for profile in "$@"; do
    contains "$profile" "${PROFILES[@]}" || fail "Unknown $PROFILE_KIND package profile: $profile"
    SELECTED_PROFILES[${#SELECTED_PROFILES[@]}]="$profile"
  done
}

install_macos_profiles() {
  local profile file
  if [ "$DRY_RUN" -eq 1 ]; then
    for profile in "${SELECTED_PROFILES[@]}"; do
      printf '+ brew bundle --file=%s --no-upgrade\n' "$PROFILE_DIR/$profile$PROFILE_EXTENSION"
    done
    return
  fi

  command -v brew >/dev/null 2>&1 || fail "Homebrew is required; install Homebrew first, then rerun this command"
  for profile in "${SELECTED_PROFILES[@]}"; do
    file="$PROFILE_DIR/$profile$PROFILE_EXTENSION"
    [ -f "$file" ] || fail "Package profile disappeared: $file"
    brew bundle --file="$file" --no-upgrade
  done
}

read_arch_profiles() {
  ARCH_PACKAGES=()
  local profile file line
  for profile in "${SELECTED_PROFILES[@]}"; do
    file="$PROFILE_DIR/$profile$PROFILE_EXTENSION"
    [ -f "$file" ] || fail "Package profile disappeared: $file"
    while IFS= read -r line || [ -n "$line" ]; do
      line=${line#"${line%%[![:space:]]*}"}
      line=${line%"${line##*[![:space:]]}"}
      case "$line" in
        ''|\#*) continue ;;
      esac
      ARCH_PACKAGES[${#ARCH_PACKAGES[@]}]="$line"
    done < "$file"
  done
}

install_arch_profiles() {
  local manager package
  read_arch_profiles
  if [ "${#ARCH_PACKAGES[@]}" -eq 0 ]; then
    printf 'No packages selected.\n'
    return
  fi

  if command -v paru >/dev/null 2>&1; then
    manager=paru
  elif command -v yay >/dev/null 2>&1; then
    manager=yay
  else
    manager=""
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    printf '+ %s -S --needed' "${manager:-paru-or-yay}"
    for package in "${ARCH_PACKAGES[@]}"; do
      printf ' %s' "$package"
    done
    printf '\n'
    return
  fi

  [ -n "$manager" ] || fail "Neither paru nor yay is installed. Install one, then rerun ./setup packages <profile>"
  command -v pacman >/dev/null 2>&1 || fail "pacman is required to check installed packages"

  missing_packages=()
  for package in "${ARCH_PACKAGES[@]}"; do
    if pacman -Q "$package" >/dev/null 2>&1; then
      printf 'Skipping installed package: %s\n' "$package"
    else
      missing_packages[${#missing_packages[@]}]="$package"
    fi
  done
  if [ "${#missing_packages[@]}" -eq 0 ]; then
    printf 'All selected packages are already installed.\n'
    return
  fi

  "$manager" -S --needed "${missing_packages[@]}"
}

install_packages() {
  select_profiles "$@"
  [ "${#SELECTED_PROFILES[@]}" -gt 0 ] || return
  case "$PROFILE_KIND" in
    macos) install_macos_profiles ;;
    arch) install_arch_profiles ;;
  esac
}

setup_terminal() {
  local terminal=${1:-}
  if [ -n "$terminal" ]; then
    contains "$terminal" ghostty kitty alacritty || fail "Unknown terminal emulator: $terminal"
  else
    [ -t 0 ] || fail "Terminal setup needs a terminal emulator argument: ghostty, kitty, or alacritty"
    choose_terminal_emulator || {
      tui_clear
      printf 'No changes made.\n'
      return
    }
    terminal=$SELECTED_TERMINAL
  fi
  link_components shell tmux nvim herdr omp opencode yazi scripts rift "$terminal"
  install_packages terminal
}

UI_BOLD=""
UI_DIM=""
UI_ACCENT=""
UI_REVERSE=""
UI_RESET=""
if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ]; then
  UI_BOLD=$(printf '\033[1m')
  UI_DIM=$(printf '\033[2m')
  UI_ACCENT=$(printf '\033[36m')
  UI_REVERSE=$(printf '\033[7m')
  UI_RESET=$(printf '\033[0m')
fi

platform_label() {
  case "$OS_KIND" in
    macos)
      printf 'macOS'
      ;;
    linux)
      if [ "$PROFILE_KIND" = "arch" ]; then
        printf 'Arch Linux'
      else
        printf 'Linux'
      fi
      ;;
    *)
      printf '%s' "$(uname -s)"
      ;;
  esac
}

default_component_selection() {
  discover_components
  SELECTED_COMPONENTS=()
  local component
  for component in "${COMPONENTS[@]}"; do
    case "$component" in
      hypr-minibook)
        continue
        ;;
      hypr|mako|waybar|wofi)
        if [ "$OS_KIND" = "linux" ] && [ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]; then
          continue
        fi
        ;;
    esac
    SELECTED_COMPONENTS[${#SELECTED_COMPONENTS[@]}]="$component"
  done
}

default_profile_selection() {
  discover_profiles
  SELECTED_TUI_PROFILES=()
  local profile
  for profile in "${PROFILES[@]}"; do
    case "$PROFILE_KIND:$profile" in
      macos:core|arch:base)
        SELECTED_TUI_PROFILES[${#SELECTED_TUI_PROFILES[@]}]="$profile"
        ;;
      arch:hyprland)
        [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] &&
          SELECTED_TUI_PROFILES[${#SELECTED_TUI_PROFILES[@]}]="$profile"
        ;;
      arch:i3)
        [ -n "${I3SOCK:-}" ] &&
          SELECTED_TUI_PROFILES[${#SELECTED_TUI_PROFILES[@]}]="$profile"
        ;;
    esac
  done
}

toggle_component() {
  local wanted=$1 item
  local updated=()
  if contains "$wanted" "${SELECTED_COMPONENTS[@]}"; then
    for item in "${SELECTED_COMPONENTS[@]}"; do
      [ "$item" = "$wanted" ] || updated[${#updated[@]}]="$item"
    done
    SELECTED_COMPONENTS=("${updated[@]}")
  else
    SELECTED_COMPONENTS[${#SELECTED_COMPONENTS[@]}]="$wanted"
  fi
}

toggle_tui_profile() {
  local wanted=$1 item
  local updated=()
  if contains "$wanted" "${SELECTED_TUI_PROFILES[@]}"; then
    for item in "${SELECTED_TUI_PROFILES[@]}"; do
      [ "$item" = "$wanted" ] || updated[${#updated[@]}]="$item"
    done
    SELECTED_TUI_PROFILES=("${updated[@]}")
  else
    SELECTED_TUI_PROFILES[${#SELECTED_TUI_PROFILES[@]}]="$wanted"
  fi
}

tui_clear() {
  if [ "${TERM:-dumb}" != "dumb" ]; then
    printf '\033[2J\033[H'
  else
    printf '\n'
  fi
}

read_tui_key() {
  if ! IFS= read -r -s -n 1 TUI_KEY </dev/tty; then
    TUI_KEY="q"
  fi
}

print_terminal_choices() {
  local cursor=$1 terminal index=0
  tui_clear
  print_tui_header
  printf '\n%sTerminal emulator%s\n\n' "$UI_BOLD" "$UI_RESET"
  for terminal in ghostty kitty alacritty; do
    if [ "$index" -eq "$cursor" ]; then
      printf '  %s>%s %s%s%s\n' \
        "$UI_ACCENT" "$UI_RESET" "$UI_REVERSE" "$terminal" "$UI_RESET"
    else
      printf '    %s\n' "$terminal"
    fi
    index=$((index + 1))
  done
  printf '\n%sj/k%s move  %sspace/enter%s select  %sq%s quit\n' \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET"
}

choose_terminal_emulator() {
  local cursor=0
  while :; do
    print_terminal_choices "$cursor"
    read_tui_key
    case "$TUI_KEY" in
      j|J) cursor=$(((cursor + 1) % 3)) ;;
      k|K) cursor=$(((cursor + 2) % 3)) ;;
      ' '|'')
        case "$cursor" in
          0) SELECTED_TERMINAL=ghostty ;;
          1) SELECTED_TERMINAL=kitty ;;
          2) SELECTED_TERMINAL=alacritty ;;
        esac
        return 0
        ;;
      q|Q) return 1 ;;
    esac
  done
}

print_tui_header() {
  printf '%sDotfiles setup%s  %s%s%s\n' \
    "$UI_BOLD" "$UI_RESET" "$UI_DIM" "$(platform_label)" "$UI_RESET"
}

print_tui_controls() {
  printf '\n%sj/k%s move  %sspace%s toggle  %sa%s all  %sn%s none  %senter%s continue  %sq%s quit\n' \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET" \
    "$UI_BOLD" "$UI_RESET"
}

print_component_choices() {
  local cursor=$1 component marker index=0
  tui_clear
  print_tui_header
  printf '\n%sConfiguration components%s\n\n' "$UI_BOLD" "$UI_RESET"
  for component in "${COMPONENTS[@]}"; do
    marker=" "
    contains "$component" "${SELECTED_COMPONENTS[@]}" && marker="x"
    if [ "$index" -eq "$cursor" ]; then
      printf '  %s>%s %s[%s] %s%s\n' \
        "$UI_ACCENT" "$UI_RESET" "$UI_REVERSE" "$marker" "$component" "$UI_RESET"
    else
      printf '    [%s] %s\n' "$marker" "$component"
    fi
    index=$((index + 1))
  done
  print_tui_controls
}

print_profile_choices() {
  local cursor=$1 profile marker index=0
  tui_clear
  print_tui_header
  printf '\n%sPackage profiles%s\n\n' "$UI_BOLD" "$UI_RESET"
  for profile in "${PROFILES[@]}"; do
    marker=" "
    contains "$profile" "${SELECTED_TUI_PROFILES[@]}" && marker="x"
    if [ "$index" -eq "$cursor" ]; then
      printf '  %s>%s %s[%s] %s%s\n' \
        "$UI_ACCENT" "$UI_RESET" "$UI_REVERSE" "$marker" "$profile" "$UI_RESET"
    else
      printf '    [%s] %s\n' "$marker" "$profile"
    fi
    index=$((index + 1))
  done
  print_tui_controls
}

choose_components_tui() {
  local cursor=0 count=${#COMPONENTS[@]}
  [ "$count" -gt 0 ] || return 0
  while :; do
    print_component_choices "$cursor"
    read_tui_key
    case "$TUI_KEY" in
      j|J)
        cursor=$(((cursor + 1) % count))
        ;;
      k|K)
        cursor=$(((cursor + count - 1) % count))
        ;;
      ' ')
        toggle_component "${COMPONENTS[$cursor]}"
        ;;
      a|A)
        SELECTED_COMPONENTS=("${COMPONENTS[@]}")
        ;;
      n|N)
        SELECTED_COMPONENTS=()
        ;;
      q|Q)
        TUI_ABORTED=1
        return 0
        ;;
      '')
        return 0
        ;;
    esac
  done
}

choose_profiles_tui() {
  local cursor=0 count=${#PROFILES[@]}
  [ "$count" -gt 0 ] || return 0
  while :; do
    print_profile_choices "$cursor"
    read_tui_key
    case "$TUI_KEY" in
      j|J)
        cursor=$(((cursor + 1) % count))
        ;;
      k|K)
        cursor=$(((cursor + count - 1) % count))
        ;;
      ' ')
        toggle_tui_profile "${PROFILES[$cursor]}"
        ;;
      a|A)
        SELECTED_TUI_PROFILES=("${PROFILES[@]}")
        ;;
      n|N)
        SELECTED_TUI_PROFILES=()
        ;;
      q|Q)
        TUI_ABORTED=1
        return 0
        ;;
      '')
        return 0
        ;;
    esac
  done
}

print_plan() {
  local item
  printf '\n%sReview%s\n' "$UI_BOLD" "$UI_RESET"
  printf '  Operating system: %s\n' "$(platform_label)"
  printf '  Configurations:\n'
  if [ "${#SELECTED_COMPONENTS[@]}" -eq 0 ]; then
    printf '    (none)\n'
  else
    for item in "${SELECTED_COMPONENTS[@]}"; do
      printf '    - %s\n' "$item"
    done
  fi
  printf '  Package profiles:\n'
  if [ "${#SELECTED_TUI_PROFILES[@]}" -eq 0 ]; then
    printf '    (none)\n'
  else
    for item in "${SELECTED_TUI_PROFILES[@]}"; do
      printf '    - %s\n' "$item"
    done
  fi
}

run_tui_plan() {
  if [ "${#SELECTED_COMPONENTS[@]}" -gt 0 ]; then
    link_components "${SELECTED_COMPONENTS[@]}"
  fi
  if [ "${#SELECTED_TUI_PROFILES[@]}" -gt 0 ]; then
    install_packages "${SELECTED_TUI_PROFILES[@]}"
  fi
}

usage() {
  printf '%s\n' \
    "Usage: ./setup [--dry-run] [list|link [component ...]|packages [profile ...]|terminal [emulator]]" \
    "" \
    "  ./setup               Review OS-aware defaults in the interactive selector" \
    "  list                  List discovered config components and package profiles" \
    "  link [component ...]  Link every leaf file from selected components (all by default)" \
    "  packages [profile ...] Install selected OS package profiles (all by default)" \
    "  terminal [emulator]   Install terminal tools; choose ghostty, kitty, or alacritty" \
    "  --dry-run             Print every planned change without applying it"
}

interactive() {
  [ -t 0 ] || fail "Interactive setup needs a terminal; use ./setup --help for command-line usage"

  default_component_selection
  default_profile_selection
  TUI_ABORTED=0

  choose_components_tui
  if [ "$TUI_ABORTED" -eq 1 ]; then
    tui_clear
    printf 'No changes made.\n'
    return 0
  fi

  [ "$PROFILE_KIND" = "unsupported" ] || choose_profiles_tui
  if [ "$TUI_ABORTED" -eq 1 ]; then
    tui_clear
    printf 'No changes made.\n'
    return 0
  fi

  tui_clear
  print_tui_header
  print_plan

  local action confirmation
  if [ "$DRY_RUN" -eq 1 ]; then
    action="p"
    printf '\n--dry-run is active; this plan will only be previewed.\n'
  else
    printf '\n[p]review only  [a]pply  [q]uit  (default: preview): '
    if ! IFS= read -r action; then
      printf '\nNo changes made.\n'
      return 0
    fi
  fi

  case "$action" in
    ''|p|P|preview)
      DRY_RUN=1
      printf '\n%sPreview%s\n' "$UI_BOLD" "$UI_RESET"
      run_tui_plan
      ;;
    a|A|apply)
      printf 'Apply this plan? [y/N]: '
      if ! IFS= read -r confirmation; then
        printf '\nNo changes made.\n'
        return 0
      fi
      case "$confirmation" in
        y|Y|yes|YES)
          DRY_RUN=0
          run_tui_plan
          ;;
        *)
          printf 'No changes made.\n'
          ;;
      esac
      ;;
    q|Q|quit)
      printf 'No changes made.\n'
      ;;
    *)
      fail "Invalid action: $action"
      ;;
  esac
}

POSITIONAL=()
for argument in "$@"; do
  case "$argument" in
    --dry-run) DRY_RUN=1 ;;
    *) POSITIONAL[${#POSITIONAL[@]}]="$argument" ;;
  esac
done
set -- "${POSITIONAL[@]}"

if [ "$#" -eq 0 ]; then
  interactive
  exit 0
fi

case "$1" in
  list)
    [ "$#" -eq 1 ] || fail "list does not take arguments"
    list
    ;;
  link)
    shift
    link_components "$@"
    ;;
  packages)
    shift
    install_packages "$@"
    ;;
  terminal)
    [ "$#" -le 2 ] || fail "terminal takes at most one emulator"
    setup_terminal "${2:-}"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    fail "Unknown action: $1"
    ;;
esac